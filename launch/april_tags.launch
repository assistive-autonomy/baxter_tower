<launch>

<!--   <rosparam file="$(find baxter_tower)/config/settings.yaml"
            command="load" />  -->

  <!-- <remap from="image_rect" to="/cameras/left_hand_camera/image"/> -->
  


  <node name="apriltag_detector"
        pkg="apriltags_ros"
        type="apriltag_detector_node"
        clear_params="true"
        output="screen">
  <remap from="image_rect" to="/cameras/left_hand_camera/image"/>
      <rosparam param="tag_descriptions">
        [{id: 1, size: 0.03, frame_id: tower},
        {id: 2, size: 0.03, frame_id: cube_2},
        {id: 3, size: 0.03, frame_id: cube_3},
        {id: 4, size: 0.03, frame_id: cube_4},
        {id: 5, size: 0.03, frame_id: cube_5}
        ]
      </rosparam>
  </node>

</launch>